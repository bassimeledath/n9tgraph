{
  "name": "n9tgraph",
  "version": "0.1.0",
  "description": "A beautiful, opinionated diagramming DSL and renderer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "n9tgraph": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "render": "tsx src/cli.ts",
    "render:all": "tsx src/render-all.ts"
  },
  "keywords": ["diagram", "dsl", "svg", "mermaid", "architecture"],
  "author": "bassimeledath",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "peggy": "^4.0.0",
    "commander": "^12.0.0",
    "@resvg/resvg-js": "^2.6.0",
    "opentype.js": "^1.3.4",
    "chokidar": "^3.6.0"
  }
}

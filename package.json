{
  "name": "n9tgraph",
  "version": "0.1.0",
  "description": "A beautiful, opinionated diagramming DSL and renderer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "n9tgraph": "dist/mcp-server.js",
    "n9tgraph-cli": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "render": "tsx src/cli.ts",
    "render:all": "tsx src/render-all.ts",
    "mcp": "tsx src/mcp-server.ts",
    "prepare": "tsc",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "diagram",
    "dsl",
    "svg",
    "mermaid",
    "architecture"
  ],
  "author": "bassimeledath",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@resvg/resvg-js": "^2.6.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "opentype.js": "^1.3.4",
    "peggy": "^4.0.0"
  }
}

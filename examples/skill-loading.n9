type flow
title The Responses API uses skills: Registry → Bundle → Runtime
direction LR

component MODELS {fill: dotgrid}
service "RESPONSES API" {fill: hero, sublabel: "System prompt: name, description, path", min-height: 120}
component "SKILL REGISTRY" {fill: dotgrid, sublabel: "name, description, object_id", min-height: 70}
component "SKILL BUNDLE STORAGE" {fill: dotgrid, sublabel: "object_id, zip", min-height: 70}
component "CONTAINER RUNTIME" {fill: dotgrid, sublabel: "/home/oai/skills/..."}

RESPONSES_API --> MODELS : COMMAND/OUTPUT

RESPONSES_API --> SKILL_REGISTRY : SKILL ID {step: 1}
RESPONSES_API --> SKILL_BUNDLE_STORAGE : EXECUTE/OUTPUT {step: 2}
MODELS --> CONTAINER_RUNTIME : COMMAND/OUTPUT {step: 3}
